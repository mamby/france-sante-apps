<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Volta.Views.PersonalHealthRecordPage"
             Title="Personal Health Record">
    <ContentPage.Resources>
        <Style TargetType="Frame" x:Key="SectionCard">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="HasShadow" Value="False" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" />
        </Style>
        <Style TargetType="Label" x:Key="SectionTitle">
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style TargetType="Label" x:Key="SectionSubtitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16,20,24">
            <Label Text="Personal Health Record"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Label Text="Keep an at-a-glance view of important health details and share them when needed."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

            <VerticalStackLayout x:Name="SectionsLayout" Spacing="10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource SectionCard}">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Title}" Style="{StaticResource SectionTitle}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding RecordCount, StringFormat='{}{0} records'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                </Grid>
                                <Label Text="{Binding Description}" Style="{StaticResource SectionSubtitle}" />
                                <Label Text="{Binding Highlight}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
                                <Label Text="{Binding LastUpdatedLabel}" Style="{StaticResource SectionSubtitle}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
