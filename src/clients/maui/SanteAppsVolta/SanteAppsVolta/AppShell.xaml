<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Volta.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Volta.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Volta">

    <Shell.TitleView>
        <Image Source="dotnet_bot.png"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
    </Shell.TitleView>

    <TabBar>
        <ShellContent Title="Home"
                      Icon="home.png"
                      Route="home"
                      ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent Title="Records"
                      Icon="people.png"
                      Route="personal-health-record"
                      ContentTemplate="{DataTemplate views:PersonalHealthRecordPage}" />

        <ShellContent Title="Alerts"
                      Icon="alert.png"
                      Route="notifications"
                      ContentTemplate="{DataTemplate views:NotificationsPage}" />

        <ShellContent Title="Profile"
                      Icon="person.png"
                      Route="profile"
                      ContentTemplate="{DataTemplate views:ProfilePage}" />

        <ShellContent Title="More"
                      Icon="more.png"
                      Route="more"
                      ContentTemplate="{DataTemplate views:MoreFeaturesPage}" />
    </TabBar>
</Shell>
